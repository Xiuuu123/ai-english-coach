# ====================================================================
# AI English Coach — 环境变量配置模板
# 复制本文件为 .env 并填入真实值（.env 不会提交到 Git）
#   cp .env.example .env
# ====================================================================

# --------------------------------------------------------------------
# LLM API 配置（必填）
# --------------------------------------------------------------------
# 默认使用 DeepSeek（国内访问稳定、价格低）
# 也可替换为 OpenAI / Azure / Claude 等任何 OpenAI 兼容 API

# API Key（必填，去对应平台申请）
VITE_API_KEY=sk-50d4b79ee6fb44ccb2852ffbcf829589

# Chat Completions 端点（OpenAI 兼容协议）
VITE_API_URL=https://api.deepseek.com/chat/completions

# 使用的模型
# DeepSeek 推荐: deepseek-chat (V3) / deepseek-reasoner (R1)
# OpenAI 推荐:    gpt-4o-mini / gpt-4o
VITE_MODEL=deepseek-chat

# --------------------------------------------------------------------
# 高级选项（可选，留空则使用默认值）
# --------------------------------------------------------------------

# API 请求超时（毫秒），默认 30000
# VITE_API_TIMEOUT=30000

# 是否启用流式响应（true / false），默认 true
# 流式响应首字延迟更低（< 300ms），推荐开启
# VITE_STREAM_ENABLED=true

# Temperature 温度参数（0-2），默认 0.7
# 越低越确定，越高越有创造性
# VITE_TEMPERATURE=0.7

# --------------------------------------------------------------------
# TTS 语音参数（可选，覆盖浏览器默认值）
# --------------------------------------------------------------------

# 语速（0.5-2.0），默认 1.0
# VITE_TTS_RATE=1.0

# 音调（0-2），默认 1.0
# VITE_TTS_PITCH=1.0

# 音量（0-1），默认 1.0
# VITE_TTS_VOLUME=1.0

# 默认口音: en-US (美式) / en-GB (英式) / en-AU (澳式)
# VITE_TTS_LANG=en-US

# --------------------------------------------------------------------
# 会员/次数配置（可选）
# --------------------------------------------------------------------

# 免费用户每场景每日可用次数，默认 7
# VITE_FREE_QUOTA_PER_SCENE=7

# VIP 标识颜色（HEX），默认 #f59e0b (金色)
# VITE_VIP_COLOR=#f59e0b

# --------------------------------------------------------------------
# 部署相关（一般无需修改）
# --------------------------------------------------------------------

# GitHub Pages 基础路径（仓库名），如部署到子路径
# 默认 / ，部署到 https://user.github.io/repo/ 时改为 /repo/
VITE_BASE_PATH=/

# 应用标题（显示在浏览器标签）
VITE_APP_TITLE=AI English Coach

# --------------------------------------------------------------------
# 安全提示
# --------------------------------------------------------------------
# ⚠️  永远不要把 .env 文件提交到 Git 仓库
# ⚠️  生产环境请使用 GitHub Secrets 等安全方式注入密钥
# ⚠️  演示用 Key 仅供本地测试，请替换为你自己的 Key
